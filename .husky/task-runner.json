{
  "tasks": [
    {
      "name": "formatting",
      "group": "pre-commit",
      "command": "treefmt",
      "args": ["${staged}"],
      "include": ["**/*"]
    },
    {
      "name": "secret-scanning",
      "group": "pre-commit",
      "command": "gitleaks",
      "args": ["protect", "--staged", "--verbose"]
    },
    {
      "name": "frontend-lint",
      "group": "pre-commit",
      "command": "bun",
      "args": ["--cwd", "client", "eslint", "--fix", "${staged}"],
      "include": ["client/**/*.ts", "client/**/*.vue", "client/**/*.js", "client/**/*.mjs"]
    },
    {
      "name": "backend-typecheck",
      "group": "pre-push",
      "command": "dotnet",
      "args": ["build", "/p:VerifyNoChanges=true"],
      "include": ["**/*.cs", "**/*.csproj"]
    },
    {
      "name": "frontend-typecheck",
      "group": "pre-push",
      "command": "bun",
      "args": ["--cwd", "client", "typecheck"]
    },
    {
      "name": "frontend-knip",
      "group": "pre-push",
      "command": "bun",
      "args": ["--cwd", "client", "knip"]
    },
    {
      "name": "backend-tests",
      "group": "pre-push",
      "command": "dotnet",
      "args": ["test"]
    },
    {
      "name": "frontend-tests",
      "group": "pre-push",
      "command": "bun",
      "args": ["--cwd", "client", "test", "run"]
    },
    {
      "name": "commit-msg-validation",
      "group": "commit-msg",
      "command": "bash",
      "args": [".husky/scripts/validate-commit.sh", "${args}"]
    }
  ]
}
