# =============================================================================
# Chatbot — Secret Schema (12-Factor)
# Primary secrets are loaded from Infisical via direnv.
# As a fallback or for local overrides, copy this file to .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (primary relational store)
# Used by: all EF Core StorageBrokers (DefaultConnection)
# -----------------------------------------------------------------------------
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=support_platform;Username=postgres;Password=CHANGE_ME

# -----------------------------------------------------------------------------
# Garnet / Redis (distributed cache + HybridCache L2)
# Used by: SharedExtensions -> StackExchangeRedisCache
# -----------------------------------------------------------------------------
ConnectionStrings__Redis=localhost:6379

# -----------------------------------------------------------------------------
# Azurite / Azure Blob Storage (document + blob storage)
# Used by: BlobBroker
# -----------------------------------------------------------------------------
ConnectionStrings__BlobStorage=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=CHANGE_ME;BlobEndpoint=http://localhost:10000/devstoreaccount1

# -----------------------------------------------------------------------------
# Qdrant (vector database for RAG)
# Used by: VectorBroker
# -----------------------------------------------------------------------------
Qdrant__Host=localhost
Qdrant__Port=6334
Qdrant__UseHttps=false
Qdrant__ApiKey=CHANGE_ME

# -----------------------------------------------------------------------------
# AI Provider (OpenRouter / OpenAI / Azure OpenAI)
# Used by: AiBroker (IChatClient)
# -----------------------------------------------------------------------------
AI__Endpoint=https://openrouter.ai/api/v1
AI__ApiKey=sk-or-v1-...
AI__ModelId=openai/gpt-4o-mini
AI__EmbeddingModelId=qwen/qwen3-embedding-8b
AI__RerankModelId=cohere/rerank-v3.5

# -----------------------------------------------------------------------------
# Docling-serve (document processing microservice)
# Used by: ProcessingBroker
# -----------------------------------------------------------------------------
Processing__BaseUrl=http://localhost:5001

# -----------------------------------------------------------------------------
# Seq (structured log ingestion)
# Used by: Serilog WriteTo.Seq sink
# -----------------------------------------------------------------------------
Serilog__WriteTo__0__Name=Seq
Serilog__WriteTo__0__Args__serverUrl=http://localhost:5341
Serilog__WriteTo__0__Args__apiKey=CHANGE_ME

# -----------------------------------------------------------------------------
# Nuxt / Frontend (NUXT_ prefix convention)
# Private keys (server-only, no NUXT_PUBLIC_ prefix):
#   runtimeConfig.databaseUrl       → NUXT_DATABASE_URL
#   runtimeConfig.redisUrl          → NUXT_REDIS_URL
#   runtimeConfig.blobStorageConnectionString → NUXT_BLOB_STORAGE_CONNECTION_STRING
#   runtimeConfig.qdrantApiKey      → NUXT_QDRANT_API_KEY
# Public keys (exposed to client, NUXT_PUBLIC_ prefix):
#   runtimeConfig.public.apiBase    → NUXT_PUBLIC_API_BASE
# -----------------------------------------------------------------------------
NUXT_DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/support_platform
NUXT_REDIS_URL=redis://localhost:6379
NUXT_BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=CHANGE_ME;BlobEndpoint=http://localhost:10000/devstoreaccount1
NUXT_QDRANT_API_KEY=CHANGE_ME
NUXT_PUBLIC_API_BASE=http://localhost:5136

# -----------------------------------------------------------------------------
# MassTransit
# Provider can be "Postgres" (default for prod) or "None" (to disable outbox)
# -----------------------------------------------------------------------------
MassTransit__Outbox__Provider=Postgres

# Infrastructure Docker Compose Secrets (avoiding repo leaks)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME
SEQ_FIRSTRUN_ADMINPASSWORDHASH=CHANGE_ME
SEQ_API_KEY=CHANGE_ME
